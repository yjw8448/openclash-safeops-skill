# Copy to /tmp/openclash-safeops.env and edit before use.
# Source it with: . /tmp/openclash-safeops.env

# Options:
# - fakeip-aethersailor
# - redirhost-smartdns
# - minimal-safe
PROFILE=fakeip-aethersailor

# Optional; never paste this in public logs.
SUB_URL=

# Strategy group names used by rule generator.
AI_GROUP=AI
DEV_GROUP=Proxy
STREAM_GROUP=Proxy
DEFAULT_GROUP=Proxy
